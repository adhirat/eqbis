# ─── Database (Neon) ──────────────────────────────────────────────────────────
# Create a personal branch in Neon dashboard → copy connection string here
DATABASE_URL=postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/eqbis?sslmode=require

# ─── Better Auth ─────────────────────────────────────────────────────────────
# Any random 32+ character string (e.g. `openssl rand -base64 32`)
BETTER_AUTH_SECRET=replace-with-32-char-random-secret
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Multi-tenant routing ────────────────────────────────────────────────────
# Use localhost:3000 for local dev. Set to your domain in staging/prod.
ROOT_DOMAIN=localhost:3000

# ─── Cloudflare R2 (optional locally — skip to disable file uploads) ─────────
# The R2 bucket binding is emulated locally by wrangler via setupDevPlatform().
# No credentials needed for the binding itself. Only set CF_R2_PUBLIC_DOMAIN if
# you need getFileUrl() to return real URLs during local dev.
CF_R2_PUBLIC_DOMAIN=
