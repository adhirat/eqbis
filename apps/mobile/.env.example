# Pass as --dart-define at run/build time. Do NOT commit actual values.
#
# Local dev:
#   flutter run --dart-define=API_BASE_URL=http://localhost:3000
#
# Staging:
#   flutter run --dart-define=API_BASE_URL=https://staging.eqbis.com
#
# Production (Codemagic sets this automatically via codemagic.yaml vars):
#   flutter build apk --dart-define=API_BASE_URL=https://eqbis.com

API_BASE_URL=http://localhost:3000
